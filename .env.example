# ─── Application ────────────────────────────────────────────────────────────────
XBRL_ENV=development
XBRL_DEBUG=false
XBRL_LOG_LEVEL=INFO
XBRL_LOG_FORMAT=json

# ─── Taxonomy ───────────────────────────────────────────────────────────────────
XBRL_TAXONOMY_CACHE_DIR=~/.xbrl-validator/cache
XBRL_TAXONOMY_CACHE_MAX_SIZE_GB=10
XBRL_TAXONOMY_REMOTE_TIMEOUT_SEC=30

# ─── Validation ─────────────────────────────────────────────────────────────────
XBRL_MAX_FILE_SIZE_MB=500
XBRL_MAX_ENTITY_EXPANSIONS=100
XBRL_MAX_ARCHIVE_SIZE_MB=1000
XBRL_MAX_ARCHIVE_FILES=5000
XBRL_VALIDATION_TIMEOUT_SEC=300

# ─── API Server ─────────────────────────────────────────────────────────────────
XBRL_API_HOST=0.0.0.0
XBRL_API_PORT=8000
XBRL_API_WORKERS=4
XBRL_API_MAX_UPLOAD_MB=200
XBRL_API_CORS_ORIGINS=["http://localhost:3000"]
XBRL_API_RATE_LIMIT=100/minute

# ─── Database ───────────────────────────────────────────────────────────────────
XBRL_DATABASE_URL=sqlite:///xbrl.db
# XBRL_DATABASE_URL=postgresql+asyncpg://xbrl:xbrl@localhost:5432/xbrl_validator
XBRL_DATABASE_POOL_SIZE=10
XBRL_DATABASE_MAX_OVERFLOW=20

# ─── Redis ──────────────────────────────────────────────────────────────────────
XBRL_REDIS_URL=redis://localhost:6379/0
XBRL_REDIS_MAX_CONNECTIONS=50

# ─── Celery Worker ──────────────────────────────────────────────────────────────
XBRL_WORKER_CONCURRENCY=4
XBRL_WORKER_MAX_TASKS_PER_CHILD=100
XBRL_WORKER_TASK_SOFT_TIME_LIMIT=300
XBRL_WORKER_TASK_HARD_TIME_LIMIT=600
XBRL_WORKER_PREFETCH_MULTIPLIER=1

# ─── Observability ──────────────────────────────────────────────────────────────
XBRL_OTEL_ENABLED=false
XBRL_OTEL_EXPORTER=otlp
XBRL_OTEL_ENDPOINT=http://localhost:4317
XBRL_OTEL_SERVICE_NAME=xbrl-validator

# ─── AI / LLM (optional) ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XBRL_AI_MODEL=claude-3-opus-20240229
# XBRL_AI_MAX_TOKENS=4096
